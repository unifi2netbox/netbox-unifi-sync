# Path on host to this plugin repository (used by docker-compose override)
UNIFI2NETBOX_PLUGIN_PATH=/absolute/path/to/unifi2netbox

# UniFi plugin configuration
UNIFI_URL=https://unifi.local
UNIFI_AUTH_MODE=api_key
UNIFI_API_KEY=
UNIFI_USERNAME=
UNIFI_PASSWORD=
UNIFI_VERIFY_SSL=true
UNIFI_DEFAULT_SITE=
UNIFI_DRY_RUN=true

# Optional NetBox API overrides (plugin resolves these internally by default)
NETBOX_API_URL=http://netbox:8080
NETBOX_TOKEN=
NETBOX_TENANT=Default
